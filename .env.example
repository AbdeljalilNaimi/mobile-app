# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# AI Chat Function (optional)
# Deploy your Firebase Cloud Function and add the URL here
VITE_AI_CHAT_FUNCTION_URL=https://your-region-your-project.cloudfunctions.net/aiChat

# N8N Webhook (optional, for AI chat via N8N)
# Get this URL from your N8N workflow webhook node
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/your-webhook-id
