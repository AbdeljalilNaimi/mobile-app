# ============================================================
# CityHealth — Capacitor APK Build Environment
# ============================================================
# Copy this file to .env.production.local before running the
# Vite build for the Android APK.  Replace the URL below with
# your deployed Replit backend URL (the "published" app URL).
# ============================================================

# The absolute URL of your deployed backend.
# All /api/* calls from the APK will go here instead of
# using the Vite dev proxy (which only works during `npm run dev`).
VITE_API_BASE_URL=https://YOUR_PROJECT.replit.app

# ============================================================
# Build steps (run these on your Windows machine)
# ============================================================
#
# 1. Install dependencies (only needed once):
#      npm install
#      npm install @capacitor/core @capacitor/cli @capacitor/android
#
# 2. Init Capacitor (only needed once):
#      npx cap init "CityHealth" "com.cityhealth.app" --web-dir dist
#
# 3. Add Android platform (only needed once):
#      npx cap add android
#
# 4. Build the Vite frontend pointing to your deployed backend:
#    Windows PowerShell:
#      $env:VITE_API_BASE_URL="https://YOUR_PROJECT.replit.app"; npx vite build
#    Windows CMD:
#      set VITE_API_BASE_URL=https://YOUR_PROJECT.replit.app && npx vite build
#    Mac/Linux:
#      VITE_API_BASE_URL=https://YOUR_PROJECT.replit.app npx vite build
#
# 5. Copy built assets into the Android project:
#      npx cap sync android
#
# 6. Open in Android Studio to build / sign / export the APK:
#      npx cap open android
#    (Then in Android Studio: Build → Generate Signed Bundle / APK)
#
# ============================================================
# Why VITE_API_BASE_URL is needed
# ============================================================
# In a Capacitor WebView, the app is loaded from file:// or
# capacitor://localhost — a relative URL like /api/... would
# try to reach the local filesystem, not your server.
# Setting VITE_API_BASE_URL to the deployed backend URL makes
# every fetch call go to the real API over HTTPS.
# ============================================================
