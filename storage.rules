rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check file size (in bytes)
    function isValidFileSize(maxSizeBytes) {
      return request.resource.size < maxSizeBytes;
    }
    
    // Helper function to check if file is an image
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // Helper function to check if file is a document (PDF, image)
    function isDocument() {
      return request.resource.contentType.matches('image/.*') 
          || request.resource.contentType == 'application/pdf';
    }
    
    // Provider documents - authenticated users can upload, only owners can read
    // Limit: 10MB, only images and PDFs allowed
    match /provider-documents/{providerId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == providerId;
      allow write: if request.auth != null 
        && request.auth.uid == providerId
        && isValidFileSize(10 * 1024 * 1024)
        && isDocument();
    }
    
    // Profile avatars - public read, owner write
    // Limit: 5MB, only images allowed
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && isValidFileSize(5 * 1024 * 1024)
        && isImage();
    }
    
    // Public assets - anyone can read, only authenticated can write
    // Limit: 10MB for any file type
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && isValidFileSize(10 * 1024 * 1024);
    }
  }
}
